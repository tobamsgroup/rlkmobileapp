{
  "expo": {
    "name": "RLKids",
    "slug": "rlkmobileapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rlkmobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tobamsgroup.rlkmobileapp",
      "NSPhotoLibraryUsageDescription": "RLKids needs access to your photo library to upload images.",
      "NSCameraUsageDescription": "RLKids needs access to your camera to take photos.",
      "NSMicrophoneUsageDescription": "RLKids  needs access to your microphone for use within the app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#DBEFDC"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tobamsgroup.rlkmobileapp",
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 1000,
          "backgroundColor": "#DBEFDC"
        }
      ],
    [
        "expo-audio",
        {
          "microphonePermission": "Allow RL4KIDS to access your microphone."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "RLKids needs access to photo library for uploading images",
          "cameraPermission": "Allow RLKids to access your camera",
          "microphonePermission": "Allow RLKids to access your microphone"
        }
      ],
      "expo-notifications",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "expo-font": {
      "fonts": [
        "./assets/fonts/WorkSans-Black.ttf",
        "./assets/fonts/WorkSans-Bold.ttf",
        "./assets/fonts/WorkSans-Medium.ttf",
        "./assets/fonts/WorkSans-Regular.ttf",
        "./assets/fonts/WorkSans-SemiBold.ttf"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "88f97a7c-0af1-4506-8677-05d74df5ecb8"
      }
    },
    "owner": "tobams_group"
  }
}
