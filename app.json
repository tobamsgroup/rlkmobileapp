{
  "expo": {
    "name": "Recycled Learning For Kids",
    "slug": "rlkmobileapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rlkmobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tobamsgroup.rlkmobileapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor":  "#DBEFDC"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tobamsgroup.rlkmobileapp",
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 1000,
          "backgroundColor": "#DBEFDC"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "expo-font": {
      "fonts": [
        "./assets/fonts/WorkSans-Black.ttf",
        "./assets/fonts/WorkSans-Bold.ttf",
        "./assets/fonts/WorkSans-Medium.ttf",
        "./assets/fonts/WorkSans-Regular.ttf",
        "./assets/fonts/WorkSans-SemiBold.ttf"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "88f97a7c-0af1-4506-8677-05d74df5ecb8"
      }
    },
    "owner": "tobams_group"
  }
}
