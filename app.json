{
  "expo": {
    "name": "Recycled Learning For Kids",
    "slug": "rlkmobileapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rlkmobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tobamsgroup.rlkmobileapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tobamsgroup.rlkmobileapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 1000,
          "backgroundColor": "#DBEFDC"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "expo-font": {
      "fonts": [
        "./assets/fonts/WorkSans-Black.ttf",
        "./assets/fonts/WorkSans-Bold.ttf",
        "./assets/fonts/WorkSans-Medium.ttf",
        "./assets/fonts/WorkSans-Regular.ttf",
        "./assets/fonts/WorkSans-SemiBold.ttf"
      ]
    }
  }
}
